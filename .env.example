# Copia a .env (no subas .env al repositorio).

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# URL pública del sitio (sin barra final). Los correos de aprobación/rechazo enlazan aquí + /iniciar-sesion.
# Si no la pones, se usa el origen del navegador del admin (p. ej. localhost en desarrollo).
# VITE_PUBLIC_SITE_URL=https://app.tudominio.com

# Resend: la API key NO debe ir en variables VITE_ (el navegador la expondría).
# En Supabase (secrets de la Edge send-email, no en Vite):
#   supabase secrets set RESEND_API_KEY=re_xxxx
#   supabase secrets set RESEND_FROM="TransLogix <onboarding@resend.dev>"
#   supabase functions deploy send-email
#   supabase functions deploy notify-admins
# Si al aprobar ves error 404 o "Failed to send…", la función no está desplegada en ese proyecto.
#
# onboarding@resend.dev sirve para pruebas; para producción verifica tu dominio en resend.com.

# Desarrollo: si tu proveedor de correo lo permite, puedes crear varias cuentas de prueba con alias en el mismo buzón.
